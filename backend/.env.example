# ── Server ────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ──────────────────────────────────────
# Local SQLite (development)
DATABASE_URL="file:./prisma/dev.db"

# Turso cloud (production) — get from https://turso.tech
# DATABASE_URL="libsql://<db-name>-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<your-turso-auth-token>"

# ── Auth ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace_with_strong_random_secret

# ── TMDB ──────────────────────────────────────────
# Get free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=replace_with_your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3

# ── CORS ──────────────────────────────────────────
# Set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:3000
